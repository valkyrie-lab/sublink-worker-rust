#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

NAME=sublink
BIN=/bin/$NAME
CONFIGFILE="/etc/sublink/config.toml"
PIDFILE="/var/run/$NAME.pid"

start_service() {
    if [ ! -f "$CONFIGFILE" ]; then
        logger -t $NAME "Config file $CONFIGFILE not found!"
        return 1
    fi

    if [ ! -x "$BIN" ]; then
        logger -t $NAME "Binary $BIN not found or not executable!"
        return 1
    fi

    logger -t $NAME "Starting $NAME..."
    procd_open_instance
    procd_set_param command "$BIN" --config "$CONFIGFILE"
    procd_set_param pidfile "$PIDFILE"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    logger -t $NAME "Stopping $NAME..."
    if [ -f "$PIDFILE" ]; then
        kill -TERM $(cat "$PIDFILE") 2>/dev/null
        rm -f "$PIDFILE"
    else
        killall -TERM $NAME 2>/dev/null
    fi
}

reload_service() {
    if [ -f "$PIDFILE" ]; then
        kill -HUP $(cat "$PIDFILE") 2>/dev/null
    fi
}

restart() {
    stop
    sleep 1
    start
}
